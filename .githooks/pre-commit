#!/usr/bin/env bash
# ABOUTME: Pre-commit hook that runs dart analyze on staged Dart files.
# ABOUTME: Skips gracefully if the Dart workspace is not yet set up.

# Check if any Dart files are staged
DART_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.dart$' || true)

if [ -z "$DART_FILES" ]; then
  exit 0
fi

# Skip if dart pub get hasn't been run yet
if [ ! -d ".dart_tool" ]; then
  echo "Skipping dart analyze — workspace not yet initialized (run 'dart pub get')"
  exit 0
fi

echo "Running dart analyze..."
dart analyze --fatal-infos || { echo "dart analyze found issues. Fix them before committing."; exit 1; }

echo "Pre-commit checks passed."
